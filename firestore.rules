rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Permitir lectura a cualquier usuario (incluyendo anónimos para la vista pública)
      allow read: if true;
      
      // Permitir escritura (crear, editar, borrar) SOLO al administrador
      // Se verifica que esté autenticado con Correo/Contraseña (no anónimo)
      allow write: if request.auth != null && request.auth.token.firebase.sign_in_provider == 'password';
    }
  }
}
